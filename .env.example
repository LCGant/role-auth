PORT=:8080
PUBLIC_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
HSTS_ENABLED=false
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
TRUST_PROXY_HEADER=false
PROXY_TRUSTED_CIDRS=
DATABASE_URL=
LOG_LEVEL=info

COOKIE_NAME=session_id
DEVICE_COOKIE_NAME=device_id
COOKIE_DOMAIN=
COOKIE_SECURE=true
COOKIE_SAMESITE=Strict

SESSION_TTL=168h
SESSION_IDLE_TTL=24h
SESSION_TOUCH_EVERY=2m
DEVICE_TTL=4320h
RESET_TTL=1h

ARGON2_MEMORY=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4
ARGON2_SALT_LENGTH=16
ARGON2_KEY_LENGTH=32

RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=1m
RATE_LIMIT_REDIS_URL=

AUTH_RATE_LIMIT_REQUESTS=8
AUTH_RATE_LIMIT_WINDOW=1m
AUTH_RATE_LIMIT_REDIS_URL=

FORGOT_RATE_LIMIT_REQUESTS=5
FORGOT_RATE_LIMIT_WINDOW=5m
FORGOT_RATE_LIMIT_REDIS_URL=

LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_WINDOW=15m
LOCKOUT_BLOCK_FOR=15m
LOCKOUT_REDIS_URL=

AUTH_INTERNAL_TOKEN=
AUTH_EMAIL_VERIFICATION_INTERNAL_TOKEN=
AUTH_ENABLE_INTERNAL_EMAIL_ISSUE=false
AUTH_METRICS_TOKEN=
DEFAULT_TENANT_ID=default

EMAIL_OUTBOX_DIR=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_REQUIRE_TLS=true
EMAIL_VERIFICATION_URL_TEMPLATE=
PASSWORD_RESET_URL_TEMPLATE=
NOTIFICATION_BASE_URL=
NOTIFICATION_INTERNAL_TOKEN=
NOTIFICATION_ALLOW_INSECURE_HTTP=false
AUDIT_BASE_URL=
AUDIT_INTERNAL_TOKEN=
AUDIT_SPOOL_DIR=
AUDIT_ALLOW_INSECURE_HTTP=false

ENCRYPTION_KEY=__GENERATE_BASE64_32_BYTES__

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/oauth/google/callback

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URL=http://localhost:8080/oauth/spotify/callback
